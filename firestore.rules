rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Data Tree ──────────────────────────────────────────────────
    // This recursive wildcard {document=**} matches:
    // 1. The user document itself: /users/{userId}
    // 2. All documents in ANY subcollection: /users/{userId}/tasks/{taskId}, etc.
    //
    // This is the most robust way to ensure that users can only access their
    // own data tree, matching the production requirement: users/{uid}/tasks/{taskId}
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}